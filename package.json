{
  "name": "cg-saas",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun run with-env turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "db:studio": "turbo run db:studio --filter=@cg-saas/db",
    "db:generate": "turbo run db:generate --filter=@cg-saas/db",
    "db:migrate": "turbo run db:migrate --filter=@cg-saas/db",
    "db:push": "turbo run db:push --filter=@cg-saas/db",
    "with-env": "dotenv -e .env --"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.2"
  },
  "packageManager": "bun@1.4.0",
  "overrides": {
    "@tamagui/core": "^2.4.0",
    "@tamagui/web": "^2.4.0",
    "@tamagui/lucide-icons": "2.0.0-rc.26",
    "tamagui": "^2.4.0"
  }
}
