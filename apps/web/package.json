{
  "name": "@cg-saas/web",
  "private": true,
  "type": "module",
  "scripts": {
    "with-env": "dotenv -e ../../.env --",
    "dev": "bun run with-env vite dev --port 3000",
    "build": "bun run tamagui-build && bun run with-env vite build",
    "preview": "bun run with-env vite preview",
    "test": "vitest run",
    "generate-routes": "tsr generate",
    "type-check": "tsc --noEmit",
    "verify-bento": "node scripts/verify-bento-v2.mjs",
    "tamagui-check": "bunx @tamagui/cli check",
    "tamagui-build": "bunx @tamagui/cli generate-css --output ./src/tamagui/tamagui.generated.css"
  },
  "dependencies": {
    "@cg-saas/api": "workspace:*",
    "@cg-saas/todos": "workspace:*",
    "@elysia/eden": "^1.4.10",
    "@tailwindcss/vite": "^4.1.18",
    "@tamagui/config": "^2.4.0",
    "@tamagui/core": "^2.4.0",
    "@tamagui/font-inter": "^2.4.0",
    "@tamagui/get-font-sized": "^2.4.0",
    "@tamagui/get-token": "^2.4.0",
    "@tamagui/linear-gradient": "^2.4.0",
    "@tamagui/lucide-icons": "2.0.0-rc.26",
    "@tamagui/roving-focus": "^2.4.0",
    "@tamagui/vite-plugin": "^2.4.0",
    "@tamagui/web": "^2.4.0",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-query": "^5.101.0",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tanstack/react-router-ssr-query": "latest",
    "@tanstack/react-start": "latest",
    "@tanstack/router-plugin": "^1.132.0",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "lucide-react": "^1.21.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-native-web": "^0.21.2",
    "tailwindcss": "^4.1.18",
    "tamagui": "^2.4.0",
    "tw-animate-css": "^1.4.0",
    "typebox": "1.2.16"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
  }
}
