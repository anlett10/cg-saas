{
  "name": "@cg-saas/api",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "with-env": "dotenv -e ../../.env --",
    "dev": "bun run with-env bun run --hot src/index.ts",
    "build": "bun run with-env bun build src/index.ts --outdir dist --target bun",
    "start": "bun run with-env bun run dist/index.js",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@cg-saas/db": "workspace:*",
    "@cg-saas/todos": "workspace:*",
    "@elysia/eden": "^1.4.10",
    "drizzle-orm": "^0.45.2",
    "elysia": "file:../../../elysia"
  },
  "devDependencies": {
    "@types/bun": "^1.1.14",
    "typescript": "^6.0.2"
  }
}
